{
  "$schema": "../schemas/combat.schema.json",
  "schema_version": 1,
  "rules_version": "0.1.0-starter",
  "_provenance": {
    "authored_by": "DESIGNER (starter values)",
    "authored_date": "2026-04-25",
    "status": "STARTER_FOR_TUNING",
    "notes": [
      "These values are internally coherent starter values designed to produce playable combat.",
      "They are NOT a reproduction of the Australian Design Group (ADG) Empires in Arms (1983) combat table.",
      "Treat every numeric value below as a tuning parameter to be revised after playtest.",
      "When changing any value, regenerate the determinism golden hash per Section 2.6 of PROMPT.md.",
      "Replace this file with licensed authentic values if Posture A (license) is taken."
    ]
  },

  "die_faces": 6,
  "die_count": 1,

  "ratio_buckets": [
    { "id": "R_1_4", "min_ratio_pct": 0,    "max_ratio_pct": 33,   "label": "1:4 or worse" },
    { "id": "R_1_3", "min_ratio_pct": 33,   "max_ratio_pct": 45,   "label": "1:3" },
    { "id": "R_1_2", "min_ratio_pct": 45,   "max_ratio_pct": 67,   "label": "1:2" },
    { "id": "R_2_3", "min_ratio_pct": 67,   "max_ratio_pct": 90,   "label": "2:3" },
    { "id": "R_1_1", "min_ratio_pct": 90,   "max_ratio_pct": 125,  "label": "1:1" },
    { "id": "R_3_2", "min_ratio_pct": 125,  "max_ratio_pct": 175,  "label": "3:2" },
    { "id": "R_2_1", "min_ratio_pct": 175,  "max_ratio_pct": 250,  "label": "2:1" },
    { "id": "R_3_1", "min_ratio_pct": 250,  "max_ratio_pct": 350,  "label": "3:1" },
    { "id": "R_4_1", "min_ratio_pct": 350,  "max_ratio_pct": 500,  "label": "4:1" },
    { "id": "R_5_1", "min_ratio_pct": 500,  "max_ratio_pct": 99999,"label": "5:1 or better" }
  ],
  "_ratio_note": "Ratios are computed as (attacker_effective_strength * 100 / defender_effective_strength). Ranges are min-inclusive, max-exclusive.",

  "formations": [
    { "id": "LINE",      "label": "Line",          "description": "Wide frontage, balanced fire and resilience." },
    { "id": "COLUMN",    "label": "Column (Assault)", "description": "Concentrated mass, strong attack into open terrain, vulnerable to fire." },
    { "id": "SQUARE",    "label": "Square",        "description": "Anti-cavalry posture, weak in protracted infantry exchange." },
    { "id": "DEFENSIVE", "label": "Defensive",     "description": "Prepared positions, reduced losses but no pursuit capability." },
    { "id": "ECHELON",   "label": "Echelon",       "description": "Refused-flank attack; rewards initiative." },
    { "id": "SKIRMISH",  "label": "Skirmish",      "description": "Light infantry / scouting posture; minimal casualties either way." }
  ],

  "formation_matrix": {
    "_doc": "Keys are 'ATTACKER_vs_DEFENDER'. Values shift the attacker's column index in the results table. Negative shifts hurt the attacker; positive shifts help. Bounded to [-2, +2].",
    "LINE_vs_LINE":          { "att_col_shift":  0, "def_morale_shift":  0 },
    "LINE_vs_COLUMN":        { "att_col_shift": 1, "def_morale_shift":  0 },
    "LINE_vs_SQUARE":        { "att_col_shift": 1, "def_morale_shift":  0 },
    "LINE_vs_DEFENSIVE":     { "att_col_shift": -1, "def_morale_shift":  0 },
    "LINE_vs_ECHELON":       { "att_col_shift":  0, "def_morale_shift":  0 },
    "LINE_vs_SKIRMISH":      { "att_col_shift": 1, "def_morale_shift":  0 },

    "COLUMN_vs_LINE":        { "att_col_shift": -1, "def_morale_shift": -1 },
    "COLUMN_vs_COLUMN":      { "att_col_shift":  0, "def_morale_shift":  0 },
    "COLUMN_vs_SQUARE":      { "att_col_shift": -1, "def_morale_shift":  0 },
    "COLUMN_vs_DEFENSIVE":   { "att_col_shift": -2, "def_morale_shift":  0 },
    "COLUMN_vs_ECHELON":     { "att_col_shift": 1, "def_morale_shift": -1 },
    "COLUMN_vs_SKIRMISH":    { "att_col_shift": 2, "def_morale_shift": -1 },

    "SQUARE_vs_LINE":        { "att_col_shift": -1, "def_morale_shift":  0 },
    "SQUARE_vs_COLUMN":      { "att_col_shift": 1, "def_morale_shift":  0 },
    "SQUARE_vs_SQUARE":      { "att_col_shift":  0, "def_morale_shift":  0 },
    "SQUARE_vs_DEFENSIVE":   { "att_col_shift": -2, "def_morale_shift":  0 },
    "SQUARE_vs_ECHELON":     { "att_col_shift": -1, "def_morale_shift":  0 },
    "SQUARE_vs_SKIRMISH":    { "att_col_shift":  0, "def_morale_shift":  0 },

    "DEFENSIVE_vs_LINE":     { "att_col_shift": 1, "def_morale_shift":  0 },
    "DEFENSIVE_vs_COLUMN":   { "att_col_shift": 2, "def_morale_shift":  0 },
    "DEFENSIVE_vs_SQUARE":   { "att_col_shift": 2, "def_morale_shift":  0 },
    "DEFENSIVE_vs_DEFENSIVE":{ "att_col_shift":  0, "def_morale_shift":  0 },
    "DEFENSIVE_vs_ECHELON":  { "att_col_shift": 1, "def_morale_shift":  0 },
    "DEFENSIVE_vs_SKIRMISH": { "att_col_shift":  0, "def_morale_shift":  0 },

    "ECHELON_vs_LINE":       { "att_col_shift":  0, "def_morale_shift": -1 },
    "ECHELON_vs_COLUMN":     { "att_col_shift": -1, "def_morale_shift":  0 },
    "ECHELON_vs_SQUARE":     { "att_col_shift": 1, "def_morale_shift":  0 },
    "ECHELON_vs_DEFENSIVE":  { "att_col_shift": -1, "def_morale_shift":  0 },
    "ECHELON_vs_ECHELON":    { "att_col_shift":  0, "def_morale_shift":  0 },
    "ECHELON_vs_SKIRMISH":   { "att_col_shift": 1, "def_morale_shift":  0 },

    "SKIRMISH_vs_LINE":      { "att_col_shift": -2, "def_morale_shift":  0 },
    "SKIRMISH_vs_COLUMN":    { "att_col_shift": -2, "def_morale_shift":  0 },
    "SKIRMISH_vs_SQUARE":    { "att_col_shift":  0, "def_morale_shift":  0 },
    "SKIRMISH_vs_DEFENSIVE": { "att_col_shift": -2, "def_morale_shift":  0 },
    "SKIRMISH_vs_ECHELON":   { "att_col_shift": -1, "def_morale_shift":  0 },
    "SKIRMISH_vs_SKIRMISH":  { "att_col_shift":  0, "def_morale_shift":  0 }
  },

  "terrain_modifiers": {
    "_doc": "Applied AFTER formation shifts. att_col_shift modifies the column index (clamped to table bounds). All shifts are integers.",
    "OPEN":     { "att_col_shift":  0, "extra_def_morale":  0 },
    "FOREST":   { "att_col_shift": -1, "extra_def_morale":  0 },
    "MOUNTAIN": { "att_col_shift": -2, "extra_def_morale": 1 },
    "MARSH":    { "att_col_shift": -1, "extra_def_morale":  0 },
    "URBAN":    { "att_col_shift": -1, "extra_def_morale": 1 },
    "RIVER_CROSSING": { "att_col_shift": -2, "extra_def_morale":  0 },
    "DESERT":   { "att_col_shift": -1, "extra_def_morale":  0 },
    "FORTRESS_LVL_1": { "att_col_shift": -1, "extra_def_morale": 1 },
    "FORTRESS_LVL_2": { "att_col_shift": -2, "extra_def_morale": 1 },
    "FORTRESS_LVL_3": { "att_col_shift": -3, "extra_def_morale": 2 }
  },

  "leader_modifiers": {
    "_doc": "Effect of the highest-tactical-rated leader on each side. Ratings 0..5. Net difference (attacker - defender) generates a column shift. Values are inclusive thresholds: a delta of 2 gives shift +1.",
    "delta_to_shift": [
      { "min_delta": -99, "max_delta": -3, "att_col_shift": -2 },
      { "min_delta":  -2, "max_delta": -1, "att_col_shift": -1 },
      { "min_delta":   0, "max_delta":  1, "att_col_shift":  0 },
      { "min_delta":   2, "max_delta":  3, "att_col_shift": 1 },
      { "min_delta":   4, "max_delta": 99, "att_col_shift": 2 }
    ],
    "army_command_bonus": {
      "_doc": "Additional shift if the leader is army-rated AND commanding 4+ corps.",
      "att_col_shift_if_active": 1
    }
  },

  "morale_modifiers": {
    "_doc": "Effective morale of a side is the average across its corps (fixed-point: morale stored as int from 0 to 10000, where 10000 = fresh). Net difference creates a column shift.",
    "_morale_scale_max": 10000,
    "delta_to_shift": [
      { "min_delta_pct": -100, "max_delta_pct": -30, "att_col_shift": -2 },
      { "min_delta_pct":  -30, "max_delta_pct": -10, "att_col_shift": -1 },
      { "min_delta_pct":  -10, "max_delta_pct":  10, "att_col_shift":  0 },
      { "min_delta_pct":   10, "max_delta_pct":  30, "att_col_shift": 1 },
      { "min_delta_pct":   30, "max_delta_pct": 100, "att_col_shift": 2 }
    ]
  },

  "composition_modifiers": {
    "_doc": "Applied based on SP composition of the engaged force. cavalry_pct = cav_sp * 100 / total_sp. Cavalry helps in OPEN terrain, hurts in FOREST/URBAN. Artillery helps generally except in MARSH. All shifts capped at +/-1 each.",
    "cavalry_advantage": {
      "_doc": "Triggered when one side has cavalry_pct >= threshold AND the other has cavalry_pct < threshold/2.",
      "threshold_pct": 20,
      "shift_in_open_terrain": 1,
      "shift_in_dense_terrain": -1,
      "dense_terrain_ids": ["FOREST", "MARSH", "URBAN", "MOUNTAIN"]
    },
    "artillery_advantage": {
      "_doc": "Triggered when one side has artillery_pct >= threshold AND the other has artillery_pct < threshold/2.",
      "threshold_pct": 10,
      "shift_general": 1,
      "shift_in_marsh": 0,
      "shift_against_fortress": 1
    }
  },

  "results_table": {
    "_doc": [
      "Outer key: ratio bucket id.",
      "Inner array: indexed 0..5 corresponding to die rolls 1..6.",
      "Each cell is { att_sp_loss, def_sp_loss, att_morale_delta, def_morale_delta, def_retreat_steps, att_advances }.",
      "Morale deltas are in the 0..10000 fixed-point scale (negative = morale loss).",
      "def_retreat_steps: 0 = hold ground; 1 = retreat 1 area; 2 = retreat 2 areas; 99 = ROUT (disperse).",
      "att_advances: true if the attacker gains the area on a successful result.",
      "If att_sp_loss > def_sp_loss substantially AND att_morale_delta worse than def's, the attacker loses (interpreted by combat resolver)."
    ],

