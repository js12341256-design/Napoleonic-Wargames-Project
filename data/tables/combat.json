  "morale_outcomes": {
    "_doc": "After morale_delta is applied, check current morale against thresholds. Triggered actions are independent.",
    "rout_threshold":      1500,
    "retreat_threshold":   3000,
    "shaken_threshold":    5000,
    "_thresholds_note": "Below threshold => action triggers. Rout: corps disperses; surviving SPs become manpower returns over 3 turns. Retreat: corps must retreat regardless of result line. Shaken: -1 column shift in next combat."
  },

  "pursuit": {
    "_doc": "Triggered when defender retreats AND attacker has cavalry_pct >= 15 AND defender's cavalry_pct < attacker's. Pursuit inflicts additional SP loss on the defender per the table below, indexed by the attacker's cavalry advantage.",
    "cavalry_advantage_brackets": [
      { "min_pct_diff":  0, "max_pct_diff": 10, "extra_def_sp_loss": 0, "extra_def_morale_delta":     0 },
