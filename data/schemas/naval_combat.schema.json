{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NavalCombatTable",
  "type": "object",
  "required": [
    "die_faces",
    "ratio_buckets",
    "results",
    "schema_version"
  ],
  "properties": {
    "die_faces": {
      "type": "integer",
      "format": "uint8",
      "minimum": 0.0
    },
    "ratio_buckets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "results": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/definitions/Maybe_for_NavalResult"
        }
      }
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "definitions": {
    "Maybe_for_NavalResult": {
      "description": "Either a designer-authored value of type `T`, or an explicit PLACEHOLDER marker.  A scenario carrying any `Placeholder` cannot ship in release per §6.1.",
      "anyOf": [
        {
          "$ref": "#/definitions/NavalResult"
        },
        {
          "$ref": "#/definitions/PlaceholderMarker"
        }
      ]
    },
    "NavalResult": {
      "type": "object",
      "required": [
        "attacker_ship_loss",
        "defender_ship_loss",
        "disengage"
      ],
      "properties": {
        "attacker_ship_loss": {
          "type": "integer",
          "format": "int32"
        },
        "defender_ship_loss": {
          "type": "integer",
          "format": "int32"
        },
        "disengage": {
          "type": "boolean"
        }
      }
    },
    "PlaceholderMarker": {
      "description": "A literal `{\"_placeholder\": true}` JSON object.",
      "type": "object",
      "required": [
        "_placeholder"
      ],
      "properties": {
        "_placeholder": {
          "type": "boolean"
        }
      }
    }
  }
}