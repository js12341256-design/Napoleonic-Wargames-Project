{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CombatTable",
  "type": "object",
  "required": [
    "die_faces",
    "formation_matrix",
    "formations",
    "ratio_buckets",
    "results_table",
    "schema_version",
    "terrain_modifiers"
  ],
  "properties": {
    "die_count": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint8",
      "minimum": 0.0
    },
    "die_faces": {
      "type": "integer",
      "format": "uint8",
      "minimum": 0.0
    },
    "formation_matrix": {
      "$ref": "#/definitions/DocumentedMap_for_FormationEntry"
    },
    "formations": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Formation"
      }
    },
    "ratio_buckets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/RatioBucket"
      }
    },
    "results_table": {
      "description": "Keyed by `ratio_bucket`; each entry has one `CombatResult` per die face (length must equal `die_faces`).",
      "allOf": [
        {
          "$ref": "#/definitions/DocumentedMap_for_Array_of_CombatResult"
        }
      ]
    },
    "rules_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "terrain_modifiers": {
      "$ref": "#/definitions/DocumentedMap_for_TerrainModifier"
    }
  },
  "definitions": {
    "CombatResult": {
      "type": "object",
      "required": [
        "att_advances",
        "att_morale_delta",
        "att_sp_loss",
        "def_morale_delta",
        "def_retreat_steps",
        "def_sp_loss"
      ],
      "properties": {
        "att_advances": {
          "type": "boolean"
        },
        "att_morale_delta": {
          "description": "Morale delta in fixed-point quarter-thousandths (`/10000`).",
          "type": "integer",
          "format": "int32"
        },
        "att_sp_loss": {
          "type": "integer",
          "format": "int32"
        },
        "def_morale_delta": {
          "type": "integer",
          "format": "int32"
        },
        "def_retreat_steps": {
          "type": "integer",
          "format": "int32"
        },
        "def_sp_loss": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "DocumentedMap_for_Array_of_CombatResult": {
      "type": "object",
      "properties": {
        "_doc": true
      }
    },
    "DocumentedMap_for_FormationEntry": {
      "type": "object",
      "properties": {
        "_doc": true
      }
    },
    "DocumentedMap_for_TerrainModifier": {
      "type": "object",
      "properties": {
        "_doc": true
      }
    },
    "Formation": {
      "type": "object",
      "required": [
        "description",
        "id",
        "label"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "FormationEntry": {
      "type": "object",
      "required": [
        "att_col_shift",
        "def_morale_shift"
      ],
      "properties": {
        "att_col_shift": {
          "type": "integer",
          "format": "int8"
        },
        "def_morale_shift": {
          "type": "integer",
          "format": "int8"
        }
      }
    },
    "RatioBucket": {
      "type": "object",
      "required": [
        "id",
        "label",
        "max_ratio_pct",
        "min_ratio_pct"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "max_ratio_pct": {
          "type": "integer",
          "format": "int32"
        },
        "min_ratio_pct": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "TerrainModifier": {
      "type": "object",
      "required": [
        "att_col_shift",
        "extra_def_morale"
      ],
      "properties": {
        "att_col_shift": {
          "type": "integer",
          "format": "int8"
        },
        "extra_def_morale": {
          "type": "integer",
          "format": "int8"
        }
      }
    }
  }
}